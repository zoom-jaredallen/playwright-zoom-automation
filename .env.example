# Zoom admin web portal credentials.
ZOOM_ADMIN_EMAIL=admin@example.com
ZOOM_ADMIN_PASSWORD=replace-me

# Zoom API authentication.
# Option A: provide a pre-generated access token.
ZOOM_API_ACCESS_TOKEN=replace-me

# Option B: leave ZOOM_API_ACCESS_TOKEN blank and use Server-to-Server OAuth.
# ZOOM_SERVER_TO_SERVER_ACCOUNT_ID=replace-me
# ZOOM_SERVER_TO_SERVER_CLIENT_ID=replace-me
# ZOOM_SERVER_TO_SERVER_CLIENT_SECRET=replace-me

# Optional base URLs.
ZOOM_WEB_BASE_URL=https://zoom.us
ZOOM_API_BASE_URL=https://api.zoom.us/v2

# Preferred address profile source.
ADDRESS_PROFILE=australia_sydney
ADDRESS_PROFILES_PATH=addresses.yaml

# Legacy direct address fields. Used when ADDRESS_PROFILE is blank, or as
# overrides when ADDRESS_PROFILE is set.
BUSINESS_ADDRESS_LINE1=55 Almaden Blvd
BUSINESS_ADDRESS_LINE2=
BUSINESS_ADDRESS_CITY=San Jose
BUSINESS_ADDRESS_STATE=CA
BUSINESS_ADDRESS_POSTAL_CODE=95113
BUSINESS_ADDRESS_COUNTRY=US
BUSINESS_ADDRESS_CUSTOMER_NAME=Example Customer
BUSINESS_ADDRESS_NUMBER_TYPE=Toll
BUSINESS_ADDRESS_CONTACT_NAME=
BUSINESS_ADDRESS_CONTACT_NUMBER=
BUSINESS_ADDRESS_CONTACT_EMAIL=

# Verification documents.
DOCUMENT_ID_PATH=/absolute/path/to/id-verification.pdf
DOCUMENT_BUSINESS_VERIFICATION_PATH=/absolute/path/to/business-verification.pdf

# Runtime controls.
HEADLESS=true
DRY_RUN=false
SUB_ACCOUNT_LIMIT=
SUB_ACCOUNT_IDS=
SUB_ACCOUNT_OWNER_FROM=
SUB_ACCOUNT_OWNER_TO=
PROGRESS_PATH=output/progress.json
ARTIFACTS_DIR=output/artifacts
FLOW_RETRY_ATTEMPTS=2
FLOW_RETRY_BASE_DELAY_MS=5000
ACCOUNT_DELAY_MS=0

# Parallel processing. Number of accounts to process concurrently.
# Each account gets its own browser context, so memory scales linearly.
# Recommended: 1-5. Default: 1 (sequential).
CONCURRENCY=1
