{
  "manifest_version": 3,
  "name": "Zoom Workflow Recorder",
  "version": "1.0.0",
  "description": "Record Zoom admin portal workflows for batch automation across sub-accounts.",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel"],
  "host_permissions": ["https://*.zoom.us/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.zoom.us/*"],
      "js": ["content/recorder.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
