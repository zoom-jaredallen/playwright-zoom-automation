{
  "name": "zoom-business-address-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Playwright automation for adding Zoom sub-account business addresses and documents.",
  "workspaces": [
    "packages/*",
    "extension"
  ],
  "scripts": {
    "build:core": "npm run build -w @zoom-automation/workflow-core",
    "build": "tsc -p tsconfig.build.json",
    "prebuild": "npm run build:core",
    "build:ui": "vite build",
    "prebuild:ui": "npm run build:core",
    "dev": "tsx src/server/index.ts",
    "predev": "npm run build:core",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretypecheck": "npm run build:core",
    "test": "vitest run",
    "pretest": "npm run build:core",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "serve:ui": "UI_DEV=false tsx src/server/index.ts",
    "preserve:ui": "npm run build:core",
    "start": "tsx src/main.ts",
    "prestart": "npm run build:core",
    "worker": "tsx src/worker/index.ts",
    "workflow:compile": "tsx src/compiler/cli.ts",
    "recorder:debug": "tsx src/recorderDebug/cli.ts",
    "recorder:latest": "tsx src/recorderDebug/cli.ts latest",
    "recorder:workflow": "tsx src/recorderDebug/cli.ts workflow",
    "recorder:actions": "tsx src/recorderDebug/cli.ts actions",
    "recorder:sessions": "tsx src/recorderDebug/cli.ts sessions",
    "recorder:events": "tsx src/recorderDebug/cli.ts events",
    "recorder:test": "tsx src/recorderDebug/cli.ts test",
    "recorder:train": "tsx src/recorderDebug/cli.ts train",
    "recorder:wait": "tsx src/recorderDebug/cli.ts wait",
    "recorder:report": "tsx src/recorderDebug/cli.ts report",
    "recorder:audit": "tsx src/recorderDebug/cli.ts audit",
    "recorder:diff": "tsx src/recorderDebug/cli.ts diff",
    "recorder:bundle": "tsx src/recorderDebug/cli.ts bundle",
    "recorder:export": "tsx src/recorderDebug/cli.ts export",
    "recorder:import": "tsx src/recorderDebug/cli.ts import",
    "recorder:reload-extension": "tsx src/recorderDebug/cli.ts reload-extension",
    "check:file-size": "node scripts/check-authored-file-size.mjs --limit=600",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@zoom-automation/workflow-core": "*",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "playwright": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.19.2",
    "vite": "^8.0.16",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
